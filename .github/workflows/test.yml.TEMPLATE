# GitHub Actions Test Workflow (Tier 2 — to be activated after tests pass)
#
# Rename this file to test.yml when ready to enable CI/CD
# Currently deferred because tests have failures (Decision 8 in HE-DECISIONS.md)

name: Tests (DISABLED - See HE-DECISIONS.md)

on:
  push:
    branches: [master, "feat/*"]
  pull_request:
    branches: [master]

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-go@v4
        with:
          go-version: '1.26'
      - name: Run tests
        run: cd src/enct-hub && go test -v ./...
      - name: Run linter
        run: cd src/enct-hub && go vet ./...
      - name: Check import boundaries
        run: |
          VIOLATIONS=$(find ./src/enct-hub -name "*.go" ! -name "*_test.go" -exec grep -l "harness\|/src/harness" {} \; | wc -l)
          if [ $VIOLATIONS -gt 0 ]; then
            echo "❌ Import boundary violations found"
            exit 1
          fi
